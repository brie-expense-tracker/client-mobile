# Required
EXPO_PUBLIC_API_URL=https://brie-staging-api.onrender.com
# Allowed: testflight | production
# For local dev/preview, set testflight
EXPO_PUBLIC_ENV=testflight

# Feature flags (public)
# 1 = enabled, 0 = disabled
EXPO_PUBLIC_AI_INSIGHTS=0
# Optional; default is false in code
# true | false
EXPO_PUBLIC_CRASH_CONSENT=false

# Logging: quiet by default (info in dev, warn in production builds).
# debug | info | warn | error | silent
# EXPO_PUBLIC_LOG_LEVEL=debug
# Force debug even in production (support only): EXPO_PUBLIC_FORCE_DEBUG=1

# Optional: run Crashlytics self-test on boot in dev (sends test breadcrumb; off by default)
# EXPO_PUBLIC_CRASH_TEST=true
